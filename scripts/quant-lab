  rows=\$((\$(wc -l < "$run_dir/candidates-\${chunk_bytes}.tsv") - 1))
  avg=\$(awk 'match(\$0, /avg_considered=([0-9.]+)/) { print substr(\$0, RSTART + 15, RLENGTH - 15) }' "$run_dir/candidates-\${chunk_bytes}.stderr.txt")
  qps=\$(awk 'match(\$0, /read_qps=([0-9.]+)/) { print substr(\$0, RSTART + 9, RLENGTH - 9) }' "$run_dir/candidates-\${chunk_bytes}.stderr.txt")
  printf '%s\t%s\t%s\t%s\t%s\n' "\$chunk_bytes" "\$elapsed_ms" "\$rows" "\${avg:-NA}" "\${qps:-NA}" >> "$run_dir/chunk-sweep.tsv"

    "$(dataset_path ecoli_mg1655_ref)" "$lab_root/data/prepared/SRR001666_1.10k.fastq" \
    --retrieval "\$mode" --top-k 20 --window 64 --stride 16 --dim 128 \
    --candidate-limit 2048 --centroids 32 --probes 4 --max-reads 1000 \
    > "\$candidates" 2> "\$log"
  end_ns=\$(date +%s%N)
  scripts/quant-lab score-minimap2-candidates "\$candidates" "$run_dir/minimap2.paf" > "\$parity"
  rows=\$((\$(wc -l < "\$candidates") - 1))
  mapped=\$(awk -F '\t' '\$1 == "scored_mapped_queries" { print \$2 }' "\$parity")
  top1=\$(awk -F '\t' '\$1 == "top1_recall" { print \$2 }' "\$parity")
  top5=\$(awk -F '\t' '\$1 == "top5_recall" { print \$2 }' "\$parity")
  top10=\$(awk -F '\t' '\$1 == "top10_recall" { print \$2 }' "\$parity")
  top20=\$(awk -F '\t' '\$1 == "top20_recall" { print \$2 }' "\$parity")
  avg=\$(awk 'match(\$0, /avg_considered=([0-9.]+)/) { print substr(\$0, RSTART + 15, RLENGTH - 15) }' "\$log")
  elapsed_ms=\$(((end_ns - start_ns) / 1000000))
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "\$mode" "\$rows" "\$mapped" "\$top1" "\$top5" "\$top10" "\$top20" "\${avg:-NA}" "\$elapsed_ms" >> "$run_dir/retrieval.tsv"
done

      [ -f "$lab_root/data/indexes/minimap2/ecoli_mg1655.sr.mmi" ] || prepare_one minimap2
      run_timed "$run_dir" "$lab_root/tools/minimap2/minimap2" -x sr -t "$bench_threads" \
        "$lab_root/data/indexes/minimap2/ecoli_mg1655.sr.mmi" \
        "$lab_root/data/prepared/SRR001666_1.10k.fastq"
      ;;
    baseline_bowtie2_ecoli)
      prepare_read_slices >/dev/null
      [ -f "$lab_root/data/indexes/bowtie2/ecoli_mg1655.1.bt2" ] || prepare_one bowtie2
      run_timed "$run_dir" "$lab_root/tools/bowtie2/bowtie2" --reorder -p "$bench_threads" \
        -x "$lab_root/data/indexes/bowtie2/ecoli_mg1655" \
        -U "$lab_root/data/prepared/SRR001666_1.10k.fastq"
      ;;
    baseline_sourmash_ecoli)
      [ -f "$lab_root/data/signatures/genomes.sig" ] || prepare_one sourmash
      [ -f "$lab_root/data/signatures/ecoli_mg1655.sig" ] || prepare_one sourmash
      run_timed "$run_dir" "$lab_root/tools/sourmash/.venv/bin/sourmash" search \
        "$lab_root/data/signatures/ecoli_mg1655.sig" "$lab_root/data/signatures/genomes.sig" \
        --containment -k 31 -o "$run_dir/search.csv"
      ;;
    baseline_spades_ecoli)
      prepare_read_slices >/dev/null
      run_timed "$run_dir" "$lab_root/tools/spades/bin/spades.py" --only-error-correction \
        -t "$bench_threads" -m 32 \
        -1 "$lab_root/data/prepared/SRR001666_1.10k.fastq" \
        -2 "$lab_root/data/prepared/SRR001666_2.10k.fastq" \
        -o "$run_dir/spades"
      ;;
    baseline_diamond_ecoli)
      [ -f "$lab_root/data/indexes/diamond/proteins.dmnd" ] || prepare_one diamond
      acquire ecoli_mg1655_protein >/dev/null
      run_timed "$run_dir" "$lab_root/tools/diamond/build/diamond" blastp \
        --threads "$bench_threads" \
        --db "$lab_root/data/indexes/diamond/proteins" \
        --query "$(dataset_path ecoli_mg1655_protein)" \
        --outfmt 6 qseqid sseqid pident length evalue bitscore \
        --out "$run_dir/diamond.tsv"
      ;;
    *)
      printf 'no command implemented for matrix row: %s\n' "$matrix_id" >&2
      exit 2
      ;;
  esac

  printf 'run_dir\t%s\n' "$run_dir"
}

run_suite() {
  local filter="${1:-ready}"
  awk -F '\t' -v filter="$filter" '
    NR == 1 { next }
    filter == "all" { print $1; next }
    filter == "ready" && $7 == "ready" { print $1; next }
    filter == "smoke" && $3 == "smoke" { print $1; next }
  ' "$repo_root/lab/matrix.tsv" |
    while IFS= read -r matrix_id; do
      printf 'run\t%s\n' "$matrix_id"
      run_matrix "$matrix_id"
    done
}

summarize() {
  printf 'run_id\tmatrix_id\ttool\tstage\tthreads\twall_time\tmax_rss_kb\trun_dir\n'
  find "$lab_root/runs" -mindepth 1 -maxdepth 1 -type d | sort |
    while IFS= read -r run_dir; do
      [ -f "$run_dir/metadata.tsv" ] || continue
      run_id="$(basename "$run_dir")"
      matrix_id="$(awk -F '\t' '$1 == "matrix_id" { print $2 }' "$run_dir/metadata.tsv")"
      awk -F '\t' -v id="$matrix_id" 'NR > 1 && $1 == id { found = 1 } END { exit !found }' \
        "$repo_root/lab/matrix.tsv" || continue
      if [ "${DINO_QUANT_SHOW_FAILED:-0}" != "1" ]; then
        awk -F ': ' 'index($0, "Exit status") && $NF == "0" { found = 1 } END { exit !found }' \
          "$run_dir/time.txt" 2>/dev/null || continue
      fi
      tool="$(awk -F '\t' '$1 == "tool" { print $2 }' "$run_dir/metadata.tsv")"
      stage="$(awk -F '\t' '$1 == "stage" { print $2 }' "$run_dir/metadata.tsv")"
      threads="$(awk -F '\t' '$1 == "threads" { print $2 }' "$run_dir/metadata.tsv")"
      wall="$(awk -F ': ' 'index($0, "Elapsed (wall clock) time") { print $NF }' "$run_dir/time.txt" 2>/dev/null || true)"
      rss="$(awk -F ': ' 'index($0, "Maximum resident set size") { print $NF }' "$run_dir/time.txt" 2>/dev/null || true)"
      printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$run_id" "$matrix_id" "$tool" "$stage" "$threads" "${wall:-NA}" "${rss:-NA}" "$run_dir"
    done
}

case "${1:-}" in
  init)
    init_lab
    ;;
  paths)
    printf 'lab_root\t%s\n' "$lab_root"
    printf 'tools\t%s/tools\n' "$lab_root"
    printf 'runs\t%s/runs\n' "$lab_root"
    printf 'data\t%s/data\n' "$lab_root"
    printf 'build_logs\t%s/build-logs\n' "$lab_root"
    printf 'patches\t%s/patches\n' "$lab_root"
    ;;
  acquire)
    shift
    acquire "$@"
    ;;
  prepare)
    shift
    prepare_one "$@"
    ;;
  prepare-assisted-minimap2)
    prepare_assisted_minimap2
    ;;
  prepare-assisted-minimap2-bundle-config)
    shift
    prepare_assisted_minimap2_bundle_config "$@"
    ;;
  tune-assisted-minimap2-bundle)
    tune_assisted_minimap2_bundle
    ;;
  new-run)
    shift
    new_run "$@"
    ;;
  run)
    shift
    run_matrix "$@"
    ;;
  run-suite)
    shift
    run_suite "$@"
    ;;
  score-minimap2-candidates)
    shift
    score_minimap2_candidates "$@"
    ;;
  score-translated-paf)
    shift
    score_translated_paf "$@"
    ;;
  optimize-retrieval)
    shift
    optimize_retrieval "$@"
    ;;
  summarize)
    summarize
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage
    exit 2
    ;;
esac

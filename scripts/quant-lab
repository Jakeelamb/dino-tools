    > "$run_dir/baseline-\${reads}.paf" 2> "$run_dir/baseline-\${reads}.stderr.txt"
  end_ns=\$(date +%s%N)
  baseline_ms=\$(((end_ns - start_ns) / 1000000))

  start_ns=\$(date +%s%N)
  /usr/bin/time -v -o "$run_dir/assisted-\${reads}.time.txt" \
    "$lab_root/tools/minimap2/minimap2" -x sr -t "$bench_threads" "\$assisted_mmi" "\$slice" \
    > "$run_dir/assisted-\${reads}.paf" 2> "$run_dir/assisted-\${reads}.stderr.txt"
  end_ns=\$(date +%s%N)
  assisted_ms=\$(((end_ns - start_ns) / 1000000))

  scripts/quant-lab score-translated-paf "$run_dir/baseline-\${reads}.paf" "$run_dir/assisted-\${reads}.paf" \
    > "$run_dir/parity-\${reads}.tsv"
  baseline_rss=\$(awk -F ': ' 'index(\$0, "Maximum resident") { print \$NF }' "$run_dir/baseline-\${reads}.time.txt")
  assisted_rss=\$(awk -F ': ' 'index(\$0, "Maximum resident") { print \$NF }' "$run_dir/assisted-\${reads}.time.txt")

  assisted_alignments=\$(awk -F '\t' '\$1 == "assisted_alignments" { print \$2 }' "$run_dir/parity-\${reads}.tsv")
  mapped_recall=\$(awk -F '\t' '\$1 == "mapped_query_recall" { print \$2 }' "$run_dir/parity-\${reads}.tsv")
  coord_parity=\$(awk -F '\t' '\$1 == "coordinate_parity" { print \$2 }' "$run_dir/parity-\${reads}.tsv")
  speedup=\$(awk -v base="\$baseline_ms" -v assisted="\$assisted_ms" 'BEGIN { if (assisted > 0) printf "%.3f", base / assisted; else print "NA" }')
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "\$reads" "\$baseline_ms" "\$assisted_ms" "\$speedup" "\$baseline_rss" "\$assisted_rss" \

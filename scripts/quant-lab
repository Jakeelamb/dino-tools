for reads in 100 1000 3000 10000; do
  slice="$run_dir/reads-\${reads}.fastq"
  if [ "\$reads" = "10000" ]; then
    slice="\$source_reads"
  else
    awk -v max_lines="\$((reads * 4))" 'NR <= max_lines { print }' "\$source_reads" > "\$slice"
  fi

  start_ns=\$(date +%s%N)
  /usr/bin/time -v -o "$run_dir/baseline-\${reads}.time.txt" \

for mode in minimizer simhash mih ivf hnsw; do
  candidates="$run_dir/candidates-\${mode}.tsv"
  parity="$run_dir/parity-\${mode}.tsv"
  log="$run_dir/candidates-\${mode}.stderr.txt"
